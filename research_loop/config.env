VERUS_VERIFY_TIMEOUT_SEC=120
COMPILE_TIMEOUT_SEC=180
DEFAULT_ROW_LIMIT=50000

# Attempt `verus` on generated MethodSpec (spec.rs).
ENABLE_VERUS_VERIFY=1

# When 1 (default): verify failure or missing verus → pipeline FAILURE (no silent SUCCESS).
# Set 0 only for local exec-only perf hacking.
REQUIRE_PROOF=1

# --- Agent / GenDB primitives (see agents/PRIMITIVES.md) ---
# If 1, transpile may emit scalar template run_query body; else skeleton for agent.
ENABLE_TEMPLATES=0
# Expose parallel TRUSTED externs (par_sum_u64, par_filter_sum_u64).
LEMMA_ENABLE_PARALLEL=0
# Vector-friendly filter+sum (build crate with --features vector_scan).
LEMMA_ENABLE_VECTOR_SCAN=0
# Spill-aware hash build (build crate with --features spill_hash).
LEMMA_ENABLE_SPILL_HASH=0
# Estimated HashSet bytes before spill stub activates (1 GiB default).
LEMMA_HASH_SPILL_BYTES=1073741824
# Column loader: lemma_columnar (plain Vec) | duckdb_like (dict strings + zone maps).
LEMMA_LOAD_FORMAT=lemma_columnar
# Bridge flag: load via DuckDB extension (stub; extension work elsewhere).
LEMMA_LOAD_FROM_DUCKDB=0
# Attach aggregate stats / zone maps to agent context.json.
LEMMA_AGENT_STATS=1
# Attach hardware profile to agent context.json.
LEMMA_AGENT_HARDWARE=1
# Attach DuckDB EXPLAIN/SUMMARIZE hints when duckdb is installed.
LEMMA_AGENT_DUCK_EXPLAIN=0

# --- OpenRouter agent sandbox (see db_extension/AGENT.md) ---
# Backend: openrouter (default) | cli (legacy Cursor Agent CLI in Docker)
LEMMA_AGENT_BACKEND=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Per-iteration wall-clock limit (host ReAct loop).
AGENT_TIMEOUT_SEC=600
# Container network: 0 = off (default). GenDB agents had web search; we default restrictive.
AGENT_NETWORK=0
# DuckDB tool data policy: none | stats (default) | full — no raw row dumps by default.
AGENT_DATA_MODE=stats
# Allow web search tool in agent container (default off).
AGENT_WEB_SEARCH=0
# Mount primer/AGENTS docs into agent context (default on).
AGENT_DOCS_MOUNT=1
# Timed measure only via host submit/harness (not agent wall-clock gaming).
AGENT_SUBMIT_ONLY_MEASURE=1
AGENT_WORKLOAD_HINT=1
AGENT_IMAGE=lemma-agent:latest
AGENT_MAX_TURNS=40

# --- Legacy CLI agent (LEMMA_AGENT_BACKEND=cli; see research_loop/AGENT_SANDBOX.md) ---
# 0 = local subprocess; 1 = Docker container (network none unless AGENT_NETWORK=1)
USE_AGENT_DOCKER=0
AGENT_CMD=agent -p --force --trust --model composer-2.5 --output-format stream-json --stream-partial-output "$(cat PROMPT.txt)"
AGENT_ENV=CURSOR_API_KEY

# Pipeline logging: OFF | ERROR | WARN | INFO | DEBUG | TRACE
LEMMA_LOG_LEVEL=INFO

# Primary optimization metric for H1 path agents: SESSION_HOT_US (GenDB hot recompute).
